# Mercator Agent — variáveis de compilação
# Copie este arquivo para .env e preencha os valores antes de compilar.

# Override do diretório de dados do agent (desenvolvimento)
MERCATOR_AGENT_HOME=""

# URL do servidor Mercator (embutida no binário)
MERCATOR_SERVER_URL="https://mercator.example.com"

# Handshake key para o endpoint de claim (embutida no binário)
MERCATOR_HANDSHAKE_KEY=""

# ID da public key de localização do servidor
MERCATOR_LOCATION_PUBLIC_KEY_ID=""

# Public key de localização em base64 (para criptografia no device)
MERCATOR_LOCATION_PUBLIC_KEY=""
